generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SRLDC
  NRLDC
  ERLDC
  WRLDC
  NERLDC
  NLDC
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(NLDC)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens        RefreshToken[]
  createdProjects      GenerationProject[]    @relation("ProjectCreator")
  projectNotes         ProjectNote[]          @relation("NoteAuthor")
  transmissionAuditLogs TransmissionAuditLog[] @relation("TxAuditAuthor")
  notifications        Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── GRID TRACKER: MASTER TABLES ──────────────────────────────────────────────

model GridRegion {
  id   String @id @default(cuid())
  code String @unique
  name String

  poolingStations      PoolingStation[]
  projects             GenerationProject[]
  transmissionElements TransmissionElement[]

  @@map("grid_regions")
}

model PlantType {
  id       String             @id @default(cuid())
  code     String             @unique
  label    String
  category GenerationCategory
  isHybrid Boolean            @default(false)

  projects GenerationProject[]

  @@map("plant_types")
}

model PoolingStation {
  id        String     @id @default(cuid())
  name      String
  voltageKv Int?
  regionId  String
  region    GridRegion @relation(fields: [regionId], references: [id])

  projects GenerationProject[]

  @@unique([name, regionId])
  @@map("pooling_stations")
}

// Master list of generating stations (imported from the canonical Station
// list spreadsheet). Drives the searchable station-name dropdown on the
// project form: picking one auto-fills + locks its pooling station + region.
// Names not in this list can still be entered free-text (no auto-fill).
model GeneratingStation {
  id                 String   @id @default(cuid())
  name               String   @unique
  poolingStationName String?
  regionCode         String?  // NR / WR / SR / ER / NER
  createdAt          DateTime @default(now())

  @@index([regionCode])
  @@map("generating_stations")
}

// ─── GRID TRACKER: CORE DOMAIN ────────────────────────────────────────────────

model GenerationProject {
  id               String          @id @default(cuid())
  name             String
  regionId         String
  region           GridRegion      @relation(fields: [regionId], references: [id])
  plantTypeId      String
  plantType        PlantType       @relation(fields: [plantTypeId], references: [id])
  poolingStationId String?
  poolingStation   PoolingStation? @relation(fields: [poolingStationId], references: [id])

  totalCapacityMw Decimal  @db.Decimal(10, 2)
  windCapacityMw  Decimal? @db.Decimal(10, 2)
  solarCapacityMw Decimal? @db.Decimal(10, 2)
  bessCapacityMw  Decimal? @db.Decimal(10, 2)

  // Per-component breakdown for hybrid projects. Populated from the
  // Excel's "Source wise Segregation of hybrid Generation Capacity" sheet
  // and consumed only by computeHybridBreakdown / Hybrid Breakdown tab.
  // Non-hybrid projects leave this null.
  hybridComponentsJson Json?

  // Whether the project is part of the FTC pipeline. The FTC page and the
  // CONTD-4 page are independent entry points: a project can be entered
  // directly into FTC without ever clearing CONTD-4 (and can be issued
  // CONTD-4 later, or never). Pipeline membership = inFtcPipeline OR a
  // CLEARED contd4 (the legacy bridge), so existing cleared projects keep
  // showing without a backfill gap.
  inFtcPipeline Boolean @default(false)

  // Active period — a project is "live" on date D when:
  //     activeFrom <= D AND (activeUntil IS NULL OR activeUntil > D)
  // Soft-delete sets activeUntil = NOW(); reactivation sets it back to NULL.
  activeFrom   DateTime  @default(now())
  activeUntil  DateTime?

  createdById String
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id])

  contd4 Contd4Application?
  phases CommissioningPhase[]
  notes  ProjectNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([activeFrom, activeUntil])
  @@map("generation_projects")
}

model Contd4Application {
  id        String            @id @default(cuid())
  projectId String            @unique
  project   GenerationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Nullable because ADMIN/NLDC may onboard a legacy project for which the
  // original CONTD-4 application date is unknown. New (PENDING/RECEIVED)
  // applications still receive a date — the action enforces that.
  applicationDate DateTime?
  proposedFtcDate DateTime?
  // Legacy: kept as a cached sum / "latest declaration" mirror so existing
  // dashboards and exports keep working unchanged. Source of truth is now the
  // Contd4Phase records below — see lib/grid-computations.js > computeContd4Study.
  capacityApr26Mw Decimal?     @db.Decimal(10, 2)
  capacityMonth   String?
  status          Contd4Status @default(UNDER_PROCESS)
  remarks         String?
  // When the `remarks` field was last edited (not the row as a whole).
  // Updating this only on remarks change lets the UI date each remark
  // accurately — the generic `updatedAt` gets bumped by other writes
  // too (phase add → refreshContd4Cache).
  remarksUpdatedAt DateTime?

  // Per-date capacity declarations. Each phase records: how much capacity was
  // declared on a specific date and which target month it counts toward.
  phases          Contd4Phase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contd4_applications")
}

// Append-only history of capacity declarations against a CONTD-4 application.
// The total declared capacity = SUM(capacityMw) across phases.
model Contd4Phase {
  id              String   @id @default(cuid())
  contd4Id        String
  contd4          Contd4Application @relation(fields: [contd4Id], references: [id], onDelete: Cascade)

  declaredDate    DateTime
  capacityMw      Decimal  @db.Decimal(10, 2)
  capacityMonth   String?   // YYYY-MM — month this capacity is expected to commission
  remarks         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contd4Id])
  @@map("contd4_phases")
}

model CommissioningPhase {
  id        String            @id @default(cuid())
  projectId String
  project   GenerationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sourceType        SourceType
  capacityAppliedMw Decimal    @db.Decimal(10, 2)

  // Legacy cached totals — kept in sync with FtcEvent / TocEvent / CodEvent
  // rows by refreshCommissioningCache(phaseId). Source of truth is now the
  // per-date event tables below. Existing readers (FtcTable, summary
  // aggregations, exports) keep reading these without change.
  ftcCompletedMw     Decimal?  @db.Decimal(10, 2)
  ftcCompletedDate   DateTime?
  proposedFtcDate    DateTime?
  capacityUnderFtcMw Decimal?  @db.Decimal(10, 2)

  tocIssuedMw        Decimal?  @db.Decimal(10, 2)
  tocIssuedDate      DateTime?
  capacityUnderTocMw Decimal?  @db.Decimal(10, 2)

  codDeclaredMw   Decimal?  @db.Decimal(10, 2)
  codDeclaredDate DateTime?
  capacityPendingCodMw Decimal? @db.Decimal(10, 2)
  expectedApr26Mw Decimal?  @db.Decimal(10, 2)
  // YYYY-MM the expectedApr26Mw value refers to. Lets users (esp. ADMIN/NLDC
  // entering back-dated data) record an "expected commissioning" against any
  // month, not just the rolling current month. Null falls back to today's
  // YYYY-MM at display time for backward compat with rows created before
  // this column existed.
  expectedMonth   String?

  delayCategory String?
  delayRemarks  String?
  otherRemarks  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes      ProjectNote[]
  ftcEvents  FtcEvent[]
  tocEvents  TocEvent[]
  codEvents  CodEvent[]

  @@index([projectId])
  @@map("commissioning_phases")
}

// Append-only per-date increment tables. The Excel files record commissioning
// step-by-step (e.g. "66.66 MW on 26-02-2026, 33.33 MW on 17-03-2026, ..."),
// and these tables capture that granularity. Total MW for each milestone =
// SUM(capacityMw) across rows; latest date = MAX(eventDate). The cached
// summary fields on CommissioningPhase are refreshed after every add/delete.
//
// Invariants enforced in server actions, not the DB:
//   SUM(TocEvent.capacityMw) <= SUM(FtcEvent.capacityMw) for a given phase
//   SUM(CodEvent.capacityMw) <= SUM(TocEvent.capacityMw) for a given phase

model FtcEvent {
  id         String   @id @default(cuid())
  phaseId    String
  phase      CommissioningPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  eventDate  DateTime
  capacityMw Decimal  @db.Decimal(10, 2)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phaseId, eventDate])
  @@map("ftc_events")
}

model TocEvent {
  id         String   @id @default(cuid())
  phaseId    String
  phase      CommissioningPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  eventDate  DateTime
  capacityMw Decimal  @db.Decimal(10, 2)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phaseId, eventDate])
  @@map("toc_events")
}

model CodEvent {
  id         String   @id @default(cuid())
  phaseId    String
  phase      CommissioningPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  eventDate  DateTime
  capacityMw Decimal  @db.Decimal(10, 2)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phaseId, eventDate])
  @@map("cod_events")
}

// ─── GRID TRACKER: AUDIT FEED ─────────────────────────────────────────────────

model ProjectNote {
  id        String             @id @default(cuid())
  // Nullable + SetNull so an audit entry survives the project being
  // hard-deleted (mirrors TransmissionAuditLog.elementId). projectName keeps a
  // readable label for orphaned audit rows.
  projectId String?
  project   GenerationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName String?
  phaseId   String?
  phase     CommissioningPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  userId    String
  user      User               @relation("NoteAuthor", fields: [userId], references: [id])
  text      String
  source    NoteSource         @default(MANUAL)
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime           @default(now())
  // Date the change is *logically* effective on (used by point-in-time replay
  // such as statusAsOf). For normal edits this equals createdAt; ADMIN/NLDC
  // may back-date a change by setting effectiveDate earlier than createdAt.
  effectiveDate DateTime?

  @@index([projectId])
  @@index([phaseId])
  @@index([effectiveDate])
  @@map("project_notes")
}

model TransmissionAuditLog {
  id          String               @id @default(cuid())
  elementId   String?
  element     TransmissionElement? @relation(fields: [elementId], references: [id], onDelete: SetNull)
  elementName String?
  userId      String
  user        User                 @relation("TxAuditAuthor", fields: [userId], references: [id])
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  createdAt   DateTime             @default(now())
  // See ProjectNote.effectiveDate. Used by txStateAsOf to replay TX state at
  // any past date; when null, falls back to createdAt.
  effectiveDate DateTime?
  // Snapshot of the element's full state AFTER this audit event. Lets
  // txStateAsOf return historical state in O(1) per element/date pair.
  // Null for legacy rows written before this column existed — replay falls
  // back to the current element row in that case.
  stateJson Json?

  @@index([elementId])
  @@index([effectiveDate])
  @@map("transmission_audit_logs")
}

enum NoteSource {
  MANUAL
  SYSTEM
}

// ─── GRID TRACKER: TRANSMISSION ───────────────────────────────────────────────

model TransmissionElement {
  id       String     @id @default(cuid())
  regionId String
  region   GridRegion @relation(fields: [regionId], references: [id])

  agencyOwner  String
  elementName  String
  elementType  TransmissionType
  isRe         Boolean          @default(false)
  voltageRatingKv Int?
  capacityMva     Decimal?      @db.Decimal(10, 2)
  lineLengthKm    Decimal?      @db.Decimal(10, 3)

  firstEnergyDate DateTime?
  pendingFtc      Boolean   @default(false)
  proposedFtcDate DateTime?

  capacityApr26Mva  Decimal? @db.Decimal(10, 2)
  lineLengthApr26Km Decimal? @db.Decimal(10, 3)

  remarks String?

  // Same soft-delete model as GenerationProject — see notes there.
  activeFrom   DateTime  @default(now())
  activeUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs TransmissionAuditLog[]

  @@index([regionId])
  @@index([activeFrom, activeUntil])
  @@map("transmission_elements")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

// Per-user notification feed surfaced in the header bell. Emitted by server
// actions (project mutations, phase events, snapshot diffs). Region-scoped at
// emit time: helpers in lib/notifications.js fan a single logical event out
// into one Notification per recipient user.
//
// Severity tiers map to the bell-icon badge color. Keep light — this is
// transient activity, not an audit log (use ProjectNote / TransmissionAuditLog
// for the durable history).

enum NotificationType {
  PROJECT_CREATED
  PROJECT_UPDATED
  CONTD4_STATUS_CHANGED
  PHASE_ADDED
  FTC_EVENT
  TOC_EVENT
  COD_EVENT
  TRANSMISSION_UPDATED
  SNAPSHOT_DIFF
  SYSTEM
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  severity  NotificationSeverity @default(INFO)
  title     String
  body      String?
  // Optional deep-link: e.g. "/generation/<projectId>" or "/dashboard".
  link      String?
  // Optional structured context for the UI (regionCode, projectId, phaseId…).
  metadata  Json?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ─── GRID TRACKER: SNAPSHOTS ──────────────────────────────────────────────────

model GridSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @db.Date
  label        String?
  t1Json       Json
  t2Json       Json
  t3Json       Json
  // Per-project & per-element data (for individual project history view).
  // Shape: { projects: [...], contd4: [...], tx: [...] }
  detailsJson  Json?
  createdAt    DateTime @default(now())

  @@unique([snapshotDate])
  @@map("grid_snapshots")
}

// ─── GRID TRACKER: ENUMS ──────────────────────────────────────────────────────

enum GenerationCategory {
  RENEWABLE
  CONVENTIONAL
  STORAGE
}

enum SourceType {
  WIND
  SOLAR
  COAL
  HYDRO
  PSP
  BESS
}

enum Contd4Status {
  UNDER_PROCESS
  CLEARED
  REJECTED
}

enum TransmissionType {
  LINE
  ICT
  GT
  ST
}
